<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="12" MinWidth="360">
        <TextBlock Text="{Binding Message}"
                   TextWrapping="Wrap" />
        <TextBlock Text="{Binding MetadataPath}"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"
                   FontFamily="Consolas" />
    </StackPanel>
</DataTemplate>
