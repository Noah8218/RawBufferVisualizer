<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <IsPackable>false</IsPackable>
    <SystemDrawingCommonVersion>8.0.8</SystemDrawingCommonVersion>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.VisualStudio.Extensibility.Sdk" Version="17.14.40608" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\RawBufferVisualizer.Sdk\RawBufferVisualizer.Sdk.csproj" />
    <ProjectReference Include="..\RawBufferVisualizer.VisualStudio\RawBufferVisualizer.VisualStudio.csproj" />
    <ProjectReference Include="..\RawBufferVisualizer.VisualStudio.ObjectSource\RawBufferVisualizer.VisualStudio.ObjectSource.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="..\..\.build\bin\RawBufferVisualizer.Core\$(Configuration)\netstandard2.0\RawBufferVisualizer.Core.dll" Link="netstandard2.0\RawBufferVisualizer.Core.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\.build\bin\RawBufferVisualizer.Sdk\$(Configuration)\netstandard2.0\RawBufferVisualizer.Sdk.dll" Link="netstandard2.0\RawBufferVisualizer.Sdk.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\.build\bin\RawBufferVisualizer.BitmapAdapter\$(Configuration)\netstandard2.0\RawBufferVisualizer.BitmapAdapter.dll" Link="netstandard2.0\RawBufferVisualizer.BitmapAdapter.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="$(NuGetPackageRoot)system.drawing.common\$(SystemDrawingCommonVersion)\lib\netstandard2.0\System.Drawing.Common.dll" Link="netstandard2.0\System.Drawing.Common.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\.build\bin\RawBufferVisualizer.VisualStudio.ObjectSource\$(Configuration)\netstandard2.0\RawBufferVisualizer.VisualStudio.ObjectSource.dll" Link="netstandard2.0\RawBufferVisualizer.VisualStudio.ObjectSource.dll">
