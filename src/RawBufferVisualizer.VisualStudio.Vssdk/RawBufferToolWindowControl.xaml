<UserControl x:Class="RawBufferVisualizer.VisualStudio.Vssdk.RawBufferToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:gl="clr-namespace:RawBufferVisualizer.OpenGlCanvas;assembly=RawBufferVisualizer.OpenGlCanvas"
             MinWidth="420"
             MinHeight="260"
             Background="#1E1E1E"
             SizeChanged="Root_SizeChanged">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#252526"/>
        <SolidColorBrush x:Key="InputBrush" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3C3C3C"/>
        <SolidColorBrush x:Key="TextBrush" Color="#F1F1F1"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9CDCFE"/>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style TargetType="{x:Type Button}">
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="MinWidth" Value="42"/>
        </Style>
        <Style TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="#1B1B1B"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="VirtualizingStackPanel.IsVirtualizing" Value="True"/>
        </Style>
        <Style TargetType="{x:Type ListBoxItem}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D2D30" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="8">
            <DockPanel LastChildFill="True">
                <TextBlock x:Name="StatusText" DockPanel.Dock="Right" Width="170" VerticalAlignment="Center" TextAlignment="Right" Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis"/>
                <WrapPanel VerticalAlignment="Center">
                    <Button Content="Open" Click="Open_Click"/>
                    <Button Content="Clear" Click="Clear_Click"/>
                    <CheckBox x:Name="LinkViewsBox" Content="Link Views" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="6,0,0,0" Checked="LinkViewsBox_Changed" Unchecked="LinkViewsBox_Changed"/>
                    <TextBlock Text="Zoom" VerticalAlignment="Center" Margin="12,0,6,0"/>
                    <Button Content="Fit" Click="Fit_Click"/>
                    <Button Content="1:1" Click="ActualSize_Click"/>
                    <Slider x:Name="ZoomSlider" Width="110" Minimum="0.01" Maximum="16" Value="1" TickFrequency="0.1" ValueChanged="ZoomSlider_ValueChanged"/>
                    <TextBlock x:Name="ZoomText" Width="58" VerticalAlignment="Center" TextAlignment="Right" Foreground="{StaticResource MutedTextBrush}"/>
                </WrapPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ImagesColumn" Width="280" MinWidth="220"/>
                <ColumnDefinition Width="*" MinWidth="220"/>
                <ColumnDefinition x:Name="InspectorColumn" Width="260" MinWidth="0"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Background="{StaticResource PanelBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="10">
                    <TextBlock DockPanel.Dock="Top" Text="Images" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ListBox x:Name="ImageList" SelectionChanged="ImageList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="66">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="76"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="66" Height="50" Background="#111111" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Image Source="{Binding Thumbnail}" Stretch="Uniform"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Summary}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>

                <Border x:Name="DescriptorPanel" Grid.Row="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="10" MaxHeight="150">
                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Top" Text="Descriptor" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <TextBlock x:Name="DescriptorText" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>

            <Border Grid.Column="1" Background="#111111" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,1,0">
                <gl:RawOpenGlImageCanvas x:Name="OpenGlImageView"/>
            </Border>

            <Grid x:Name="InspectorPanel" Grid.Column="2" Background="{StaticResource PanelBrush}" Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="140"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="10">
                    <TextBlock Text="Pixel" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock x:Name="PixelText" Margin="0,6,0,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                </StackPanel>

                <Border Grid.Row="1" Margin="10,0,10,0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Background="{StaticResource InputBrush}">
                    <Canvas x:Name="HistogramCanvas" Margin="8"/>
                </Border>

                <TextBlock Grid.Row="2" Text="Diagnostics" FontSize="16" FontWeight="SemiBold" Margin="10,12,10,8"/>
                <ListBox Grid.Row="3" x:Name="DiagnosticsList" Margin="10,0,10,10"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
